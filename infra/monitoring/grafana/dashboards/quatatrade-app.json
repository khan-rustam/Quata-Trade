{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "QuataTrade — App & Business",
  "uid": "quatatrade-app",
  "schemaVersion": 39,
  "tags": ["quatatrade"],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Users", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "quata_users_total", "refId": "A" }]
    },
    {
      "type": "stat", "title": "Alerts (1h)", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "quata_alerts_last_hour", "refId": "A" }]
    },
    {
      "type": "stat", "title": "Stuck broadcasts", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "quata_stuck_broadcasts", "refId": "A" }]
    },
    {
      "type": "stat", "title": "API req/s", "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(quata_http_requests_total[5m]))", "refId": "A" }]
    },
    {
      "type": "stat", "title": "API p95 latency (s)", "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(quata_http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "HTTP request rate by status", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum by (status) (rate(quata_http_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "HTTP latency p50 / p95 / p99 (s)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(quata_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(quata_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(quata_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries", "title": "Withdrawals by status", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [{ "expr": "quata_withdrawals", "legendFormat": "{{status}}", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "Trades by status", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [{ "expr": "quata_trades", "legendFormat": "{{status}}", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "Deposits by status", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [{ "expr": "quata_deposits", "legendFormat": "{{status}}", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "API process memory (RSS bytes)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "process_resident_memory_bytes{service=\"api\"}", "legendFormat": "rss", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "Node.js event-loop lag (s)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds{service=\"api\"}", "legendFormat": "lag", "refId": "A" }]
    }
  ]
}

{
  "name": "@quatatrade/backend",
  "version": "0.1.0",
  "private": true,
  "description": "QuataTrade API + worker — NestJS 11 modular monolith (Fastify)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.1.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/websockets": "^11.0.0",
    "@quatatrade/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bullmq": "^5.34.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.2",
    "kysely": "^0.28.0",
    "minio": "^8.0.3",
    "nestjs-pino": "^4.3.0",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^5.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "tronweb": "^6.0.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.0"
  }
}

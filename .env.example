# ============================================================
# QuataTrade backend environment — COPY TO backend/.env
# Never commit a real .env. Dev defaults match docker-compose.yml.
# ============================================================

NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Database -------------------------------------------------
# App role (restricted: no UPDATE/DELETE on append-only tables)
# NOTE: dev compose maps Postgres to host port 55432 (5432/5433 host native PGs)
DATABASE_URL=postgres://quatatrade_app:app_dev_only@localhost:55432/quatatrade
# Owner role — used ONLY by migrations
DATABASE_MIGRATION_URL=postgres://quatatrade:quatatrade_dev_only@localhost:55432/quatatrade
# Password the migration assigns to the app role (dev default)
DATABASE_APP_PASSWORD=app_dev_only

# --- Redis ----------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth / crypto --------------------------------------------
# openssl rand -base64 48  (dev values below are placeholders)
JWT_ACCESS_SECRET=dev_only_change_me_jwt_access_secret_min_32_chars
JWT_ACCESS_TTL_SECONDS=600
REFRESH_TTL_DAYS=30
# 32-byte base64 master key for encrypting TOTP secrets / KYC file keys (sodium)
# openssl rand -base64 32
MASTER_ENCRYPTION_KEY=ZGV2X29ubHlfbWFzdGVyX2tleV9jaGFuZ2VfbWVfISE=
# Enforce admin step-up 2FA on sensitive actions (withdrawal approve/reject,
# dispute resolve, kill switch, settings, ledger adjustment). MUST be true in
# production (the app refuses to boot otherwise). Enroll every admin's 2FA
# during the test phase, THEN set this true for prod.
ADMIN_2FA_REQUIRED=false

# --- MinIO (S3) -----------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=quatatrade
MINIO_SECRET_KEY=quatatrade_dev_only
# SSE-S3 at-rest encryption of uploaded objects (KYC/PII). REQUIRED in production.
# When true, MinIO must have KMS configured (e.g. MINIO_KMS_SECRET_KEY). Leave
# false in dev where MinIO has no KMS.
STORAGE_SSE_ENABLED=false

# --- SMTP ------------------------------------------------------
# DEV: mailpit/mailhog on localhost:1025 (notifications log-only if unreachable).
# PRODUCTION (Hostinger email) — set these in backend/.env on the server:
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465                 # SSL/TLS. (Use 587 with SMTP_SECURE=false for STARTTLS.)
#   SMTP_SECURE=true              # true for 465, false for 587
#   SMTP_USER=no-reply@quatatrade.com     # your FULL Hostinger mailbox address
#   SMTP_PASS=<mailbox-password>
#   SMTP_FROM=QuataTrade <no-reply@quatatrade.com>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=QuataTrade <no-reply@quatatrade.local>

# --- TRON -----------------------------------------------------
# shasta | nile | mainnet
TRON_NETWORK=shasta
TRONGRID_API_URL=https://api.shasta.trongrid.io
TRONGRID_API_KEY=
TRON_FALLBACK_RPC_URL=
# Canonical USDT TRC20 contract. Mainnet: TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# For testnet use the contract of the test token you deploy/use.
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
DEPOSIT_CONFIRMATIONS=19
DEPOSIT_MIN_AMOUNT=1000000

# Watch-only account extended public key (xpub) — NEVER the seed/xprv.
# Generated offline by a human per Documents/03-architecture.md.
WALLET_XPUB=

# Signer hot-wallet address (base58). Enables the on-chain reserve check
# (reconciliation job compares its USDT balance vs ledger obligations).
# Recommended in production; leave blank to disable the check.
WALLET_HOT_ADDRESS=

# --- Signer (isolated service, human-written) ------------------
# mock = dev/testnet stub inside worker (never in production)
SIGNER_MODE=mock
SIGNER_URL=
SIGNER_CA_CERT_PATH=
SIGNER_CLIENT_CERT_PATH=
SIGNER_CLIENT_KEY_PATH=

# --- ClamAV ---------------------------------------------------
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Misc -----------------------------------------------------
SWAGGER_ENABLED=true
LOG_LEVEL=debug
